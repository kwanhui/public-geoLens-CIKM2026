# Trim the Docker build context — the Dockerfile only COPYs what's needed,
# but excluding these here speeds up `docker build` and HF Space builds.

.git
.github
.gitignore
.pre-commit-config.yaml

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
venv/
.venv/

# Test + lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Tests not needed in the runtime image
tests/

# Repo-level docs not needed in the image
NEXT_SESSION.md
IMPLEMENTATION_PLAN.md
CHANGELOG.md
PROGRESS.md
PROJECT.md
docs/


# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/
